# ═══════════════════════════════════════════════════════════════
# A.L.E.C. — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=3001
NEURAL_PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_HEX_STRING

# ── Admin Account (seeded on first startup) ──────────────────
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Model Configuration ──────────────────────────────────────
MODEL_PATH=data/models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
MODEL_CONTEXT_LENGTH=4096
N_GPU_LAYERS=-1
NEURAL_BACKEND=llama-cpp

# ── A.L.E.C. Database (Azure SQL — optional) ────────────────
# If not set, SQLite fallback at data/alec.db is automatic.
# AZURE_SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=yourdb;Uid=user;Pwd=pass;Encrypt=yes;

# ── Stoa Group Database (for continuous learning) ────────────
# Only needed if A.L.E.C. should learn from Stoa real estate data.
# STOA_DB_HOST=your-server.database.windows.net
# STOA_DB_PORT=1433
# STOA_DB_NAME=stoagroupDB
# STOA_DB_USER=your-user
# STOA_DB_PASSWORD=your-password
# STOA_DB_SSL=true

# ── Home Assistant (optional) ────────────────────────────────
# HOME_ASSISTANT_URL=http://your-ha-ip:8123
# HOME_ASSISTANT_ACCESS_TOKEN=your-long-lived-token

# ── Voice ────────────────────────────────────────────────────
VOICE_INTERFACE_ENABLED=true
# VOICE_PORT=3002

# ── Vercel (for remote access proxy) ────────────────────────
# ALEC_LOCAL_URL=http://your-tailscale-ip:3001
