# ═══════════════════════════════════════════════════════════════
# A.L.E.C. — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=3001
NEURAL_PORT=8000
HOST=0.0.0.0
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_HEX_STRING

# Remote admin: allows executing shell commands via /api/admin/exec
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# If blank, the endpoint is disabled (returns 403 for all requests).
ADMIN_SECRET=

# ── Admin Account (seeded on first startup) ──────────────────
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Model Configuration ──────────────────────────────────────
MODEL_PATH=data/models/qwen2.5-coder-7b-instruct-q4_k_m.gguf
MODEL_CONTEXT_LENGTH=4096
N_GPU_LAYERS=-1
NEURAL_BACKEND=llama-cpp

# ── A.L.E.C. Database (Azure SQL — optional) ────────────────
# If not set, SQLite fallback at data/alec.db is automatic.
# AZURE_SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=yourdb;Uid=user;Pwd=pass;Encrypt=yes;

# ── Stoa Group Database (for continuous learning) ────────────
# Only needed if A.L.E.C. should learn from Stoa real estate data.
# STOA_DB_HOST=your-server.database.windows.net
# STOA_DB_PORT=1433
# STOA_DB_NAME=stoagroupDB
# STOA_DB_USER=your-user
# STOA_DB_PASSWORD=your-password
# STOA_DB_SSL=true

# ── Home Assistant (optional) ────────────────────────────────
# HOME_ASSISTANT_URL=http://your-ha-ip:8123
# HOME_ASSISTANT_ACCESS_TOKEN=your-long-lived-token

# ── Voice ────────────────────────────────────────────────────
VOICE_INTERFACE_ENABLED=true
# VOICE_PORT=3002

# ── Vercel (for remote access proxy) ────────────────────────
# ALEC_LOCAL_URL=http://your-tailscale-ip:3001

# ── Proactive Email (A.L.E.C. sends updates/reports to owner) ──
# Uses Gmail SMTP. Get an App Password: Google Account → Security → App Passwords
ALERT_GMAIL_USER=your-gmail@gmail.com
ALERT_GMAIL_APP_PASSWORD=your-app-password
ALERT_EMAIL_TO=owner@example.com

# ── Web Search (for AI research and fact-checking) ──────────
# Brave Search API: https://api.search.brave.com/
# SEARCH_API_KEY=your-brave-search-key

# ── Plaid (brokerage account linking) ───────────────────────
# Sign up at https://dashboard.plaid.com/ to get credentials
# PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ── Microsoft Graph / SharePoint ────────────────────────────
# One-time setup: az login && node scripts/setup-azure-ad.js
# This registers "ALEC Assistant" in Azure AD and writes all three vars below.
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-client-secret
# Email address of the user whose SharePoint/OneDrive to access (app-level client_credentials flow)
MS_USER_EMAIL=alec@abodingo.com

# ── Gmail Integration ─────────────────────────────────────────
# Step 1: Create OAuth 2.0 Desktop credentials in Google Cloud Console
#   → console.cloud.google.com → APIs & Services → Credentials → Create OAuth Client ID → Desktop app
# Step 2: Enable Gmail API for the project
# Step 3: Run: node scripts/gmail-oauth.js
#   → Opens auth URL for each account, writes refresh tokens below

# OAuth2 credentials (shared across both accounts, from Google Cloud Console)
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret

# Account email addresses (used for display and OAuth login_hint)
GMAIL_ALEC_EMAIL=rovneralec@gmail.com
GMAIL_PROPERTIES_EMAIL=rovnerproperties@gmail.com

# Refresh tokens — written automatically by: node scripts/gmail-oauth.js
# Never expire (unless revoked). Store securely.
GMAIL_REFRESH_TOKEN_ALEC=your-refresh-token-for-rovneralec
GMAIL_REFRESH_TOKEN_PROPERTIES=your-refresh-token-for-rovnerproperties

# ── iMessage Alerts ───────────────────────────────────────────
# Phone number to receive URGENT email alerts and task notifications
# Format: 10-digit US number without country code (e.g. 2154857259)
OWNER_PHONE=2154857259
