{
  "name": "alec-desktop",
  "version": "2.0.2",
  "description": "A.L.E.C. Desktop Control Center",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.rovner.alec",
    "productName": "ALEC",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "icon": "assets/alec.icns"
    },
    "dmg": {
      "title": "ALEC Installer",
      "icon": "assets/alec.icns"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "arovn10",
        "repo": "A.L.E.C",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "alec",
        "filter": [
          "backend/**/*",
          "frontend/dist/**/*",
          "frontend/package.json",
          "services/**/*",
          "!services/neural/__pycache__/**",
          "!services/neural/.venv/**",
          "!services/neural/data/**",
          "routes/**/*",
          "dataConnectors/**/*",
          "config/**/*",
          "scripts/restart-neural.sh",
          "data/alec-brain.db",
          ".env",
          "package.json",
          "package-lock.json",
          "node_modules/**/*",
          "!**/*.map",
          "!**/*.log",
          "!**/.DS_Store"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-fetch": "^3.3.2"
  }
}
