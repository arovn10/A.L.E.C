{
  "name": "a-l-e-c",
  "version": "2.0.0",
  "description": "A.L.E.C. — Autonomous Language Embedded Cognition: Self-improving AI agent with local LLM inference and LoRA fine-tuning",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "neural": "cd services/neural && source .venv/bin/activate && python server.py",
    "setup": "bash scripts/setup-local.sh",
    "download-model": "bash scripts/download-model.sh",
    "start:full": "bash scripts/start-alec.sh",
    "build": "echo 'No build step required'",
    "test": "jest"
  },
  "keywords": [
    "ai",
    "llm",
    "personal-assistant",
    "adaptive-learning",
    "lora",
    "qwen",
    "local-inference",
    "self-improving"
  ],
  "author": "Alec Rovner",
  "license": "PROPRIETARY",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.25.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ws": "^8.5.11",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
