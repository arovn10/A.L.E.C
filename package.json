{
  "name": "a-l-e-c-personal-ai",
  "version": "1.0.0",
  "description": "Adaptive Learning Executive Companion - Your Personal AI Assistant",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "echo 'No build step required'",
    "test": "jest --testEnvironment=node --forceExit --detectOpenHandles",
    "test:ci": "jest --testEnvironment=node --forceExit --detectOpenHandles --ci --coverage"
  },
  "keywords": [
    "ai",
    "llm",
    "personal-assistant",
    "adaptive-learning",
    "voice-interface"
  ],
  "author": "Alec Rovner",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.25.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ws": "^8.5.11",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testEnvironment": "node",
    "verbose": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
