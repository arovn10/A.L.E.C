{
  "name": "a-l-e-c",
  "version": "2.0.0",
  "description": "A.L.E.C. — Adaptive Learning Executive Coordinator: Self-improving AI agent with local LLM inference, LoRA fine-tuning, and autonomous knowledge acquisition",
  "main": "backend/server.js",
  "scripts": {
    "dev:backend": "nodemon backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "start": "NODE_ENV=production node backend/server.js",
    "neural": "cd services/neural && source .venv/bin/activate && python server.py",
    "setup": "bash scripts/setup-local.sh",
    "download-model": "bash scripts/download-model.sh",
    "start:full": "bash scripts/start-alec.sh",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "lint": "node -c backend/server.js && node -c services/neuralEngine.js && node -c frontend/app.js"
  },
  "keywords": [
    "ai",
    "llm",
    "autonomous-agent",
    "self-improving",
    "lora",
    "qwen",
    "local-inference",
    "real-estate",
    "personal-ai"
  ],
  "author": "Alec Rovner",
  "license": "PROPRIETARY",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.25.0",
    "@lmstudio/sdk": "^1.5.0",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.2.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-llama-cpp": "^3.18.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "puppeteer-core": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "weaviate-ts-client": "^2.2.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ws": "^8.5.11",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testMatch": ["<rootDir>/tests/**/*.test.(js|mjs)", "<rootDir>/__tests__/**/*.test.(js|mjs)"],
    "testPathIgnorePatterns": ["/node_modules/", "/.claude/"],
    "moduleFileExtensions": ["js", "mjs", "json"]
  }
}
